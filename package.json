{
  "name": "mini-watch-server",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.4",
  "description": "首尔服务器监控 + AI Agent 状态面板",
  "license": "ISC",
  "scripts": {
    "dev": "NODE_ENV=development PORT=3001 tsx watch src/index.tsx",
    "dev:client": "vite --clearScreen false --strictPort",
    "start": "node dist/index.js",
    "build": "tsc && tsc-alias --resolve-full-paths",
    "build:client": "vite build",
    "bundle": "pnpm build:client && tsx scripts/build.ts",
    "prod": "node dist/bundle.cjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/core": "^14.3.0",
    "animejs": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "lucide-vue-next": "^1.0.0",
    "nanoid": "^5.1.11",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "unstorage": "^1.17.5",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "dayjs": "^1.11.20",
    "esbuild": "^0.27.7",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.1.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.14",
    "vite-plugin-html": "^3.2.2",
    "vue-tsc": "^3.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "esbuild@0.27.7",
      "esbuild@0.28.0",
      "vue-demi"
    ]
  }
}